{
  "name": "@oak/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./remark": {
      "import": "./dist/remark/index.js",
      "types": "./dist/remark/index.d.ts"
    },
    "./astro": {
      "import": "./dist/astro/index.js",
      "types": "./dist/astro/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "ulid": "^2.3.0",
    "unist-util-visit": "^5.0.0"
  },
  "peerDependencies": {
    "astro": ">=5.0.0",
    "unified": ">=11.0.0"
  },
  "peerDependenciesMeta": {
    "astro": {
      "optional": true
    },
    "unified": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mdast": "^4.0.4",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.0",
    "rehype-stringify": "^10.0.0",
    "unified": "^11.0.5"
  }
}
